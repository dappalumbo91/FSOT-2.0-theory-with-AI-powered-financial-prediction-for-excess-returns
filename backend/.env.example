# FSOT Market Monitor — copy to .env (never commit real keys)
# Broker is DRY-RUN by default. Live requires all three flags below.

# --- Robinhood Crypto (optional; for wiring / future use) ---
# Create key: https://robinhood.com/account/crypto (desktop web classic)
FSOT_RH_API_KEY=
# Path to Ed25519 private key PEM (or set B64 instead)
FSOT_RH_PRIVATE_KEY_PATH=
# FSOT_RH_PRIVATE_KEY_B64=
# FSOT_RH_BASE_URL=https://trading.robinhood.com
FSOT_BROKER_MAX_ORDER_USD=100

# Safety — leave as-is for synthetic / dry-run only
FSOT_BROKER_DRY_RUN=1
# FSOT_BROKER_LIVE=0
# FSOT_BROKER_I_UNDERSTAND=
# Live trading ONLY when you set:
#   FSOT_BROKER_LIVE=1
#   FSOT_BROKER_I_UNDERSTAND=YES
#   FSOT_BROKER_DRY_RUN=0
